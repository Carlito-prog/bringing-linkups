{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/privacy-policy/layout,_N_T_/privacy-policy/page,_N_T_/privacy-policy"},"segmentPaths":["/_tree","/_full","/privacy-policy/__PAGE__","/privacy-policy","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><link rel=\"preconnect\" href=\"/\" crossorigin=\"\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0tr12~4s47ki0.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0yb2wil16uz6h.js\"/><script src=\"/_next/static/chunks/0vvnhg1esx5rg.js\" async=\"\"></script><script src=\"/_next/static/chunks/0whvh662-zl_q.js\" async=\"\"></script><script src=\"/_next/static/chunks/0yg0xd_tkxv2h.js\" async=\"\"></script><script src=\"/_next/static/chunks/0pqt~8bl3ukh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-07z8uqmghuln0.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zig0fh30t6ou.js\" async=\"\"></script><script src=\"/_next/static/chunks/01zvdfwl3~-n7.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0e_dd4ck4r6qd.js\" async=\"\"></script><script src=\"/_next/static/chunks/00zkvlhjd9bwf.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Bringing Link Ups (BLU)</title><meta name=\"description\" content=\"BLU is a social event platform designed to use content to connect people through real-world experiences, nearby events, and shared interests.\"/><meta property=\"og:title\" content=\"Bringing Link Ups (BLU)\"/><meta property=\"og:description\" content=\"Discover events, meet people nearby, and build real-world connections with BLU.\"/><meta property=\"og:url\" content=\"https://www.bringinglinkups.com\"/><meta property=\"og:site_name\" content=\"Bringing Link Ups\"/><meta property=\"og:image\" content=\"https://www.bringinglinkups.com/images/live-feed.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Bringing Link Ups\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Bringing Link Ups (BLU)\"/><meta name=\"twitter:description\" content=\"Scroll through content to find events and meaningful real-world connections nearby.\"/><meta name=\"twitter:image\" content=\"https://www.bringinglinkups.com/images/live-feed.png\"/><link rel=\"icon\" href=\"/images/live-events.png\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"inter_9925b6be-module__Yu3A7G__variable merriweather_991431b6-module__vCCE8W__variable antialiased bg-[url(&#x27;/images/asphalt.png&#x27;)] bg-repeat text-white w-screen min-h-screen m-0 p-0\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"max-w-[1600px] mx-auto relative\"><section class=\"flex justify-between items-center p-4\"><div class=\"relative w-[50px] h-[50px] md:w-[60px] md:h-[60px] z-50\"><a href=\"/\"><img alt=\"logo\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" src=\"/images/blu-icon.svg\"/></a></div><header class=\"relative flex items-center justify-between\"><nav class=\"hidden md:flex flex-1 mx-6 overflow-hidden relative z-10\"><ul class=\"flex justify-center gap-8 font-medium text-white md:text-xl transition-transform duration-300 translate-x-full opacity-0 pointer-events-none\"><li class=\"cursor-pointer\"><span><a href=\"/why-blu\">Why BLU</a></span></li><li class=\"cursor-pointer\"><span><a href=\"/founders\">The Founders</a></span></li><li class=\"cursor-pointer\"><span><a href=\"/competitors\">Competitors</a></span></li><li class=\"cursor-pointer\"><span><a href=\"/contact\">Contact Us</a></span></li></ul></nav><button class=\"relative cursor-pointer flex flex-col gap-1 md:gap-2 transition-all z-50\"><span class=\"block h-[5px] w-[40px] md:w-[50px] bg-[#dcff00] transition-all duration-300 \"></span><span class=\"block h-[5px] w-[40px] md:w-[50px] bg-[#dcff00] transition-all duration-300 -translate-x-3\"></span><span class=\"block h-[5px] w-[40px] md:w-[50px] bg-[#dcff00] transition-all duration-300 \"></span></button><div class=\"fixed inset-0 bg-black/75 transition-[transform-opacity] duration-500 opacity-0 pointer-events-none\"></div><aside class=\"fixed top-20 right-4 w-[240px] rounded-sm bg-[#2d72ff] shadow-xl transform transition-transform duration-500 ease-in-out md:hidden z-10 translate-x-[120%]\"><ul class=\"text-xl px-6 py-6 space-y-4 text-white\"><li class=\"cursor-pointer border-b border-white/20 pb-3 hover:text-[#dcff00]\"><a href=\"/why-blu\">Why BLU</a></li><li class=\"cursor-pointer border-b border-white/20 pb-3 hover:text-[#dcff00]\"><a href=\"/founders\">The Founders</a></li><li class=\"cursor-pointer border-b border-white/20 pb-3 hover:text-[#dcff00]\"><a href=\"/competitors\">Competitors</a></li><li class=\"cursor-pointer pt-2 hover:text-[#dcff00]\"><a href=\"/contact\">Contact Us</a></li></ul></aside></header></section></div><div style=\"overflow:hidden;width:100%\"><div style=\"min-height:100vh;width:100%;position:relative;opacity:0;transform:translateY(800px) scale(0.96)\"><section class=\"bg-white text-black max-h-screen w-full md:max-w-3/5 mx-auto my-4 md:my-10 p-4 md:p-16 relative overflow-y-scroll\"><header class=\"mb-8\"><h1 class=\"text-4xl md:text-5xl font-extrabold leading-tight\">Privacy Settings &amp; User Controls</h1><p class=\"mt-2 text-md\">BLU is committed to empowering users with control over their visibility and interactions.</p><p class=\"mt-2 text-md\">Users may configure privacy settings within the app, including:</p></header><div class=\"space-y-8 text-base leading-relaxed\"><div><h2 class=\"text-2xl font-bold my-4\">1. Profile Visibility</h2><p class=\"mb-4\">Users may choose:</p><ul class=\"list-disc pl-6 space-y-2 mt-4\"><li>Public Profile (visible to all users)</li></ul></div><div><h2 class=\"text-2xl font-bold my-4\">2. Event Participation Visibility</h2><p class=\"mb-4\">Users may control:</p><ul class=\"list-disc pl-6 space-y-2 mt-4\"><li>Whether their attendance is publicly displayed</li><li>Whether they appear in “Entered” event lists</li><li>Whether they appear in Maps</li></ul><p class=\"mb-4\">Private events are only by invitations or by search.</p></div><div><h2 class=\"text-2xl font-bold my-4\">3. Location Controls</h2><p class=\"mb-4\">Users may:</p><ul class=\"list-disc pl-6 space-y-2 mt-4\"><li>Enable precise location</li><li>Enable approximate location</li></ul><p class=\"mb-4\">Disabling location may limit app usage.</p></div><div><h2 class=\"text-2xl font-bold my-4\">4. Messaging Controls</h2><p class=\"mb-4\">Users may choose:</p><ul class=\"list-disc pl-6 space-y-2 mt-4\"><li>Event participants only</li><li>Direct messages</li><li>Create group message</li></ul><p class=\"mb-4\">Users may block or report other users at any time.</p></div><div><h2 class=\"text-2xl font-bold my-4\">5. Data Access &amp; Deletion</h2><p class=\"mb-4\">Users may:</p><ul class=\"list-disc pl-6 space-y-2 mb-4\"><li>Request deletion of account and associated data</li></ul><p class=\"mb-4\">Deletion requests may take up to 30 days to process, subject to legal obligations.</p></div><div><h2 class=\"text-2xl font-bold my-4\">6. Analytics &amp; Demographic Insights</h2><p class=\"mb-4\">BLU may provide aggregated demographic insights to event hosts. These insights:</p><ul class=\"list-disc pl-6 space-y-2 mt-4\"><li>Do not reveal personal identities</li><li>Are anonymized</li><li>Are used for improving event experiences</li></ul></div><div><h2 class=\"text-2xl font-bold my-4\">7. Safety &amp; Moderation</h2><p class=\"mb-4\">BLU reserves the right to:</p><ul class=\"list-disc pl-6 space-y-2 mt-4\"><li>Remove harmful content</li><li>Investigate reported behavior</li><li>Cooperate with law enforcement when required</li></ul></div></div></section><!--$--><!--/$--></div></div><div class=\"bg-black\"><section class=\"xs:flex-col md:flex justify-between items-center max-w-[1600px] mx-auto p-4 space-y-1 md:space-y-0\"><div class=\"text-sm md:text-base\">© 2024 - 2026 Bringing Link Ups LLC. All Rights Reserved.</div><div class=\"text-sm md:text-base\"><a class=\"text-[#dcff00] hover:underline\" href=\"/terms-of-service\">Terms of Service</a> | <a class=\"text-[#dcff00] hover:underline\" href=\"/privacy-policy\">Privacy Policy</a></div><div class=\"socials flex gap-2 md:gap-4\"><a href=\"#\"><div class=\"text-[#dcff00]\"><svg fill=\"none\" height=\"20\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"20\" xmlns=\"http://www.w3.org/2000/svg\"><rect height=\"20\" rx=\"5\" ry=\"5\" width=\"20\" x=\"2\" y=\"2\" opacity=\"1\" pathLength=\"1\" stroke-dashoffset=\"0\" stroke-dasharray=\"1 1\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\" opacity=\"1\" pathLength=\"1\" stroke-dashoffset=\"0\" stroke-dasharray=\"1 1\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\" opacity=\"1\" pathLength=\"1\" stroke-dashoffset=\"0\" stroke-dasharray=\"1 1\"></line></svg></div></a><a href=\"#\"><div class=\"text-[#dcff00]\"><svg fill=\"none\" height=\"20\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"20\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z\" opacity=\"1\" pathLength=\"1\" stroke-dashoffset=\"0\" stroke-dasharray=\"1 1\"></path></svg></div></a