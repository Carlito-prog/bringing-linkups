{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/fba5a26ea33df6a3-s.p.0eehd8tgys7nv.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0tr12~4s47ki0.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0q-wtwwppgvv3.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0yb2wil16uz6h.js\"/><script src=\"/_next/static/chunks/0vvnhg1esx5rg.js\" async=\"\"></script><script src=\"/_next/static/chunks/0whvh662-zl_q.js\" async=\"\"></script><script src=\"/_next/static/chunks/0yg0xd_tkxv2h.js\" async=\"\"></script><script src=\"/_next/static/chunks/0pqt~8bl3ukh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-07z8uqmghuln0.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zig0fh30t6ou.js\" async=\"\"></script><script src=\"/_next/static/chunks/01zvdfwl3~-n7.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0e_dd4ck4r6qd.js\" async=\"\"></script><script src=\"/_next/static/chunks/13z.udx3nzse4.js\" async=\"\"></script><script src=\"/_next/static/chunks/0wulhcxi..r3n.js\" async=\"\"></script><script src=\"/_next/static/chunks/0~hiqq8gi~ul..js\" async=\"\"></script><script src=\"/_next/static/chunks/00zkvlhjd9bwf.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Bringing Link Ups (BLU)</title><meta name=\"description\" content=\"BLU is a social event platform designed to use content to connect people through real-world experiences, nearby events, and shared interests.\"/><meta property=\"og:title\" content=\"Bringing Link Ups (BLU)\"/><meta property=\"og:description\" content=\"Discover events, meet people nearby, and build real-world connections with BLU.\"/><meta property=\"og:url\" content=\"https://www.bringinglinkups.com\"/><meta property=\"og:site_name\" content=\"Bringing Link Ups\"/><meta property=\"og:image\" content=\"https://www.bringinglinkups.com/images/live-feed.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Bringing Link Ups\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Bringing Link Ups (BLU)\"/><meta name=\"twitter:description\" content=\"Scroll through content to find events and meaningful real-world connections nearby.\"/><meta name=\"twitter:image\" content=\"https://www.bringinglinkups.com/images/live-feed.png\"/><link rel=\"icon\" href=\"/images/live-events.png\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"inter_9925b6be-module__Yu3A7G__variable merriweather_991431b6-module__vCCE8W__variable antialiased bg-[url(&#x27;/images/asphalt.png&#x27;)] bg-repeat text-white w-screen min-h-screen m-0 p-0\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"max-w-[1600px] mx-auto relative\"><section class=\"flex justify-between items-center p-4\"><div class=\"relative w-[50px] h-[50px] md:w-[60px] md:h-[60px] z-50\"><a href=\"/\"><img alt=\"logo\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" src=\"/images/blu-icon.svg\"/></a></div><header class=\"relative flex items-center justify-between\"><nav class=\"hidden md:flex flex-1 mx-6 overflow-hidden relative z-10\"><ul class=\"flex justify-center gap-8 font-medium text-white md:text-xl transition-transform duration-300 translate-x-full opacity-0 pointer-events-none\"><li class=\"cursor-pointer\"><span><a href=\"/why-blu\">Why BLU</a></span></li><li class=\"cursor-pointer\"><span><a href=\"/founders\">The Founders</a></span></li><li class=\"cursor-pointer\"><span><a href=\"/competitors\">Competitors</a></span></li><li class=\"cursor-pointer\"><span><a href=\"/contact\">Contact Us</a></span></li></ul></nav><button class=\"relative cursor-pointer flex flex-col gap-1 md:gap-2 transition-all z-50\"><span class=\"block h-[5px] w-[40px] md:w-[50px] bg-[#dcff00] transition-all duration-300 \"></span><span class=\"block h-[5px] w-[40px] md:w-[50px] bg-[#dcff00] transition-all duration-300 -translate-x-3\"></span><span class=\"block h-[5px] w-[40px] md:w-[50px] bg-[#dcff00] transition-all duration-300 \"></span></button><div class=\"fixed inset-0 bg-black/75 transition-[transform-opacity] duration-500 opacity-0 pointer-events-none\"></div><aside class=\"fixed top-20 right-4 w-[240px] rounded-sm bg-[#2d72ff] shadow-xl transform transition-transform duration-500 ease-in-out md:hidden z-10 translate-x-[120%]\"><ul class=\"text-xl px-6 py-6 space-y-4 text-white\"><li class=\"cursor-pointer border-b border-white/20 pb-3 hover:text-[#dcff00]\"><a href=\"/why-blu\">Why BLU</a></li><li class=\"cursor-pointer border-b border-white/20 pb-3 hover:text-[#dcff00]\"><a href=\"/founders\">The Founders</a></li><li class=\"cursor-pointer border-b border-white/20 pb-3 hover:text-[#dcff00]\"><a href=\"/competitors\">Competitors</a></li><li class=\"cursor-pointer pt-2 hover:text-[#dcff00]\"><a href=\"/contact\">Contact Us</a></li></ul></aside></header></section></div><div style=\"overflow:hidden;width:100%\"><div style=\"min-height:100vh;width:100%;position:relative;opacity:0;transform:translateY(800px) scale(0.96)\"><main class=\"h-full\"><section class=\"before:content-[&#x27;&#x27;] before:absolute before:h-[850px] before:w-full before:-z-21 before:bg-[linear-gradient(to_top,rgba(17,17,17,.7)_0%,rgba(17,17,17,.1)_100%)] before:-top-[80px] after:content-[&#x27;&#x27;] after:absolute after:-top-[60px] after:h-[850px] after:w-full after:-z-20 after:bg-[url(&#x27;/images/blu-icon-grid.svg&#x27;)] after:bg-repeat after:bg-center after:opacity-45 p-4\"><div class=\"max-w-[1600px] mx-auto flex flex-col justify-center\"><div class=\"flex flex-col justify-center items-center gap-1 px-5 h-[500px] md:h-[650px] text-center\"><h2 class=\"font-medium text-lg md:text-3xl pb-2 tracking-[.1rem] md:tracking-[.2rem] uppercase\">Bringing Link Ups</h2><hr class=\"bg-[#fff]/75 border-0 h-[1px] w-[15%]\"/><h1 class=\"font-bold font-serif -mt-2 text-[3.25rem] md:text-[8rem] leading-[1]\">Your <span class=\"align-text-bottom inline-block text-[#2d72ff] \"><div class=\"overflow-hidden py-2\"><h1 class=\"\" style=\"opacity:0;transform:translateY(-50px)\">Interests</h1></div></span></h1><p class=\"font-light text-lg md:text-2xl \">BLU is a social event platform that helps you discover people, media,<br class=\"hidden md:block\"/>and events aligned to your interests and location — all in one place.</p><div class=\"flex flex-col sm:flex-row mt-4 md:mt-8 gap-4 md:gap-6\"><button class=\"border-[.25px] border-white cursor-pointer flex items-center justify-center gap-2 rounded-sm text-sm md:text-lg w-[185px] h-[60px] hover:bg-[#2d72ff] hover:border-black hover:text-white\"><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 384 512\" class=\"fill-[#dcff00]\" height=\"45\" width=\"45\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z\"></path></svg><span class=\"flex flex-col items-start\"><span class=\"text-sm/3\">Download on the</span><span class=\"text-xl md:text-2xl/7\">App Store</span></span></button><button class=\"plus_jakarta_sans_9d252999-module__7GZZRa__variable border-[.25px] border-white cursor-pointer flex items-center justify-center gap-2 font-medium rounded-sm text-sm md:text-lg w-[185px] h-[60px] hover:bg-[#2d72ff] hover:border-black hover:text-white\"><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 512 512\" class=\"fill-[#dcff00]\" height=\"40\" width=\"40\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z\"></path></svg><span class=\"flex flex-col items-start\"><span class=\"md:text-base/4 uppercase\">Get it on</span><span class=\" md:text-xl/7\">Google Play</span></span></button></div></div></div></section><section class=\"bg-[#171717] hidden md:block\"></section><section class=\"bg-[#2d72ff] bg-[url(/images/blu-text-pattern.svg)] bg-cover\"><section class=\"flex flex-col md:flex-row justify-between items-center gap-10 md:gap-20 max-w-[1600px] min-h-[500px] mx-auto md:pt-5\"><div class=\"flex flex-col xs:pb-4 md:px-4 md:pt-4 w-full md:w-1/2 order-2 md:order-2\" style=\"opacity:0;transform:translateX(80px)\"><section class=\"flex flex-col max-w-[1600px] mx-auto px-5 md:px-0\"><ul><li class=\"flex items-center gap-10 pb-5 md:text-xl\"><span class=\"w-[30px]\"><div class=\"text-[#2a4797]\"><svg fill=\"none\" height=\"40\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"40\" xmlns=\"http://www.w3.org/2000/svg\" style=\"transform:none\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\" opacity=\"1\"></circle></svg></div></span>Finding events and coordinating plans often means juggling multiple apps, group chats, and calendars.</li><li class=\"flex items-center gap-10 pb-5 md:text-xl\"><span class=\"w-[30px]\"><div class=\"text-[#dcff00]\"><svg fill=\"none\" height=\"40\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"40\" xmlns=\"http://www.w3.org/2000/svg\" style=\"transform:none\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\" opacity=\"1\"></circle></svg></div></span>Technology meant to connect us has turned simple plans into friction‑filled tasks.</li><li class=\"flex items-center gap-10 pb-5 md:text-xl\"><span class=\"w-[30px]\"><div class=\"text-white\"><svg fill=\"none\" height=\"40\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"40\" xmlns=\"http://www.w3.org/2000/svg\" style=\"transform:none\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\" opacity=\"1\"></circle></svg></div></span>Busy schedules and vague plans lead to missed moments and connections that never happen.</li></ul></section></div><div class=\"flex flex-col xs:p-4 md:px-4 md:pt-4 w-full md:w-1/2 order-1 md:order-1\" style=\"opacity:0;transform:translateX(-80px)\"><section class=\"flex flex-col max-w-[1600px] mx-auto p-5\"><h2 class=\"uppercase text-lg text-white tracking-[.2rem]\">The Dilemma</h2><h1 class=\"font-bold font-serif mb-3 py-2 text-5xl md:text-6xl\">Connection is Easy, \n Coordination is Not.</h1><p class=\"text-lg md:text-xl\">Blu helps surface experiences that align with what you enjoy, so you spend less time searching and more time showing up.</p></section></div></section></section><section class=\"flex flex-col md:flex-row justify-between items-center gap-10 md:gap-20 max-w-[1600px] min-h-[500px] mx-auto md:pt-5\"><div class=\"flex flex-col xs:pb-4 md:px-4 md:pt-4 w-full md:w-1/2 order-2 md:order-1\" style=\"opacity:0;transform:translateX(-80px)\"><section class=\"overflow-hidden relative w-full h-[300px] md:min-h-[500px]\"><img alt=\"live events\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover object-top\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" src=\"/images/trend-discover.png\"/></section></div><div class=\"flex flex-col xs:p-4 md:px-4 md:pt-4 w-full md:w-1/2 order-1 md:order-2\" style=\"opacity:0;transform:translateX(80px)\"><section class=\"flex flex-col max-w-[1600px] mx-auto p-5\"><h2 class=\"uppercase text-lg text-[#2d72ff] tracking-[.2rem]\">The Solution</h2><h1 class=\"font-bold font-serif mb-3 py-2 text-5xl md:text-6xl\">One Place to Plan, <br/> Share, and <span class=\"text-[#dcff00]\">Link Up</span></h1><p class=\"text-lg md:text-xl\">BLU creates one place to discover, coordinate, and experience events — built around shared interests so linking up feels natural.</p></section></div></section><section class=\"bg-[#2d72ff] bg-[url(/images/blu-text-pattern.svg)] bg-cover\"><section class=\"flex flex-col md:flex-row justify-between items-center gap-10 md:gap-20 max-w-[1600px] min-h-[500px] mx-auto md:pt-5\"><div class=\"flex flex-col xs:pb-4 md:px-4 md:pt-4 w-full md:w-1/2 order-2 md:order-2\" style=\"opacity:0;transform:translateX(80px)\"><section class=\"overflow-hidden relative w-full h-[300px] md:min-h-[500px]\"><img alt=\"community\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover object-top\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" src=\"/images/community.png\"/></section></div><div class=\"flex flex-col xs:p-4 md:px-4 md:pt-4 w-full md:w-1/2 order-1 md:order-1\" style=\"opacity:0;transform:translateX(-80px)\"><section class=\"flex flex-col max-w-[1600px] mx-auto p-5\"><h2 class=\"uppercase text-lg text-white tracking-[.2rem]\">The Culture</h2><h1 class=\"font-bold font-serif mb-3 py-2 text-5xl md:text-6xl\">Community is Everything</h1><p class=\"text-lg md:text-xl\">BLU is built around shared interests and proximity — not followers, likes, or algorithms.</p></section></div></section></section><section class=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 place-content-evenly font-serif gap-10 max-w-[1600px] min-h-[500px] mx-auto p-5 text-center\"><div class=\"flex flex-col items-center gap-3\"><div class=\"text-[#dcff00]\"><svg fill=\"none\" height=\"50\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"50\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M5.8 11.3 2 22l10.7-3.79\"></path><path d=\"M11 13c1.93 1.93 2.83 4.17 2 5-.83.83-3.07-.07-5-2-1.93-1.93-2.83-4.17-2-5 .83-.83 3.07.07 5 2Z\"></path><path d=\"M4 3h.01\"></path><path d=\"M22 8h.01\"></path><path d=\"M15 2h.01\"></path><path d=\"M22 20h.01\"></path><path d=\"m14 10 1.21-1.06c0.16-0.84 0.9-1.44 1.76-1.44h0.38c0.88 0 1.55-0.77 1.45-1.63a2.9 2.9 0 0 1 1.96-3.12L22 2\"></path><path d=\"M17 15h0.77c0.71 0 1.32-0.52 1.43-1.22c0.16-0.91 1.12-1.45 1.98-1.11L22 13\"></path><path d=\"M9 7V6.23c0-0.71 0.52-1.33 1.22-1.43c0.91-0.16 1.45-1.12 1.11-1.98L11 2\"></path></svg></div><h3 class=\"font-bold font-serif text-4xl\">Discover &amp; create events</h3><p class=\"font-sans text-md md:text-2xl\">Find what’s happening nearby — or start \n something in seconds.</p></div><div class=\"flex flex-col items-center gap-3\"><div class=\"text-[#dcff00]\"><svg fill=\"none\" height=\"50\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"50\" xmlns=\"http://www.w3.org/2000/svg\"><rect height=\"14\" rx=\"2\" width=\"18\" x=\"3\" y=\"3\"></rect><path d=\"M4 21h1\"></path><path d=\"M9 21h1\"></path><path d=\"M14 21h1\"></path><path d=\"M19 21h1\"></path></svg></div><h3 class=\"font-bold font-serif text-4xl\">Share moments &amp; media</h3><p class=\"font-sans text-md md:text-2xl\">Posts, clips, chats, and rooms — all connected \n to real plans.</p></div><div class=\"flex flex-col items-center gap-3\"><div class=\"text-[#dcff00]\"><svg fill=\"none\" height=\"50\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"50\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect height=\"18\" rx=\"2\" width=\"18\" x=\"3\" y=\"4\"></rect><path d=\"M3 10h18\"></path><circle cx=\"8\" cy=\"14\" fill=\"currentColor\" r=\"1\" stroke=\"none\" opacity=\"1\"></circle><circle cx=\"12\" cy=\"14\" fill=\"currentColor\" r=\"1\" stroke=\"none\" opacity=\"1\"></circle><circle cx=\"16\" cy=\"14\" fill=\"currentColor\" r=\"1\" stroke=\"none\" opacity=\"1\"></circle><circle cx=\"8\" cy=\"18\" fill=\"currentColor\" r=\"1\" stroke=\"none\" opacity=\"1\"></circle><circle cx=\"12\" cy=\"18\" fill=\"currentColor\" r=\"1\" stroke=\"none\" opacity=\"1\"></circle><circle cx=\"16\" cy=\"18\" fill=\"currentColor\" r=\"1\" stroke=\"none\" opacity=\"1\"></circle></svg></div><h3 class=\"font-bold font-serif text-4xl\">Schedule, chat &amp; show up</h3><p class=\"font-sans text-md md:text-2xl\">Schedule events, get reminders, and map \n your way there—all in one place.</p></div></section><section class=\"bg-[#2d72ff] bg-[url(/images/blu-text-pattern.svg)] bg-cover\"><section class=\"flex flex-col gap-10 max-w-[1600px] mx-auto p-4 md:py-10\"><div class=\"text-center\"><h2 class=\"uppercase text-lg tracking-[.2rem]\">Frequently Asked Questions</h2><h1 class=\"font-bold font-serif mb-3 py-2 text-5xl md:text-6xl\">Your questions answered here.</h1></div><div class=\"flex gap-10\"><div class=\"faq-titles bg-[#181a1c]/30 flex flex-col w-1/3 md:w-1/5\"><h2 class=\"bg-[#181a1c] capitalize cursor-pointer p-2 text-white md:text-2xl text-center\">General</h2><h2 class=\" capitalize cursor-pointer p-2 text-white md:text-2xl text-center\">App</h2><h2 class=\" capitalize cursor-pointer p-2 text-white md:text-2xl text-center\">Safety</h2></div><div class=\"faq-wrapper cursor-pointer w-2/3 md:w-full min-h-[500px]\"><div class=\"block faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">What is Bringing Link Ups (BLU)?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">BLU is a platform for discovering, creating, and connecting around shared interests through real-world events powered by media and community engagement.</p></div><div class=\"block faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">Who is BLU for?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">BLU is built for people who want more than just event listings. It’s for community builders, event curators, and anyone looking to form real connections around nearby shared interests.</p></div><div class=\"block faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">What makes BLU different from other event or social apps?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">BLU focuses on real-world interaction, not endless feeds. With BLU Rooms, interactive maps, and interest-based discovery, you can connect before, during, and after events—not just RSVP and disappear.</p></div><div class=\"hidden  faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">What is a BLU Room?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">A BLU Room is the hub for an event. It’s where organizers and attendees connect, share media, chat, promote to nearby users, and turn online engagement into real-world experiences.</p></div><div class=\"block faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">Can I use BLU even if I don’t attend events often?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">Yes. You can explore events, follow interests, and engage with communities online before deciding to attend anything in person.</p></div><div class=\"hidden  faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">How do I find events near me?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">BLU uses your location and interests to recommend nearby events. You can browse and filter by interest, location, age group, or time.</p></div><div class=\"hidden  faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">Can I create and host my own events?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">Yes. You can create public or private events, manage RSVPs, invite people, and host ticketed or free experiences directly through the app.</p></div><div class=\"hidden  faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">How do tickets and payments work?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">Tickets are purchased securely through the BLU app using Stripe. Event organizers receive payouts directly through the platform.</p></div><div class=\"block faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">Are refunds available for ticketed events?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">No. All ticket sales are final.</p></div><div class=\"hidden  faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">Is BLU safe to use?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">BLU prioritizes community safety through organizer transparency, user reporting, and event history. You can view ratings, reviews, and past Rooms before attending.</p></div><div class=\"hidden  faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">Can I report inappropriate behavior?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">Yes. Users and incidents can be reported directly in the app, and our team will review and take action when necessary.</p></div><div class=\"hidden  faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">How is my information protected?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">BLU uses encryption, secure servers, and privacy controls to protect your data. Your activity and profile visibility are always in your control.</p></div><div class=\"block faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">How much does BLU cost?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">BLU is free to use.</p></div><div class=\"hidden  faq border-t-[.25] border-[#181a1c] overflow-hidden p-2 cursor-pointer\"><div class=\"flex justify-between items-center py-4\"><h3 class=\"font-medium md:text-2xl\">How do I sign up?</h3><span><svg stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" viewBox=\"0 0 448 512\" color=\"white\" class=\"translate-all rotate-0 ease-in-out duration-300\" style=\"color:white\" height=\"1em\" width=\"1em\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\"></path></svg></span></div><p class=\"h-0 opacity-0 overflow-hidden transition-all duration-300 text-white md:text-xl\">Download the BLU app and request a signup code. An admin will review your request and reach out with next steps.</p></div></div></div></section></section></main><!--$--><!--/$--></div></div><div class=\"bg-black\"><section class=\"xs:flex-col md:flex justify-between items-center max-w-[1600px] mx-auto p-4 space-y-1 md:space-y-0\"><div class=\"text-sm md:text-base\">© 2024 - 2026 Bringing Link Ups LLC. All Rights Reserved.</div><div class=\"text-sm md:text-base\"><a class=\"text-[#dcff00] hover:underline\" href=\"/terms-of-service\">Terms of Service</a> | <a class=\"text-[#dcff00] hover:underline\" href=\"/privacy-policy\">Privacy Policy</a></div><div class=\"socials flex gap-2 md:gap-4\"><a href=\"#\"><div class=\"text-[#dcff00]\"><svg fill=\"none\" height=\"20\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewBox=\"0 0 24 24\" width=\"20\" xmlns=\"http://www.w3.org/2000/svg\"><rect height=\"20\" rx=\"5\" ry=\"5\" width=\"20\" x=\"2\" y=\"2\" opacity=\"1\" pathLength=\"1\" stroke-dashoffset=\"0\" stroke-dasharray=\"1 1\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 